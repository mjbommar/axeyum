{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axeyum.local/schemas/rules-core.schema.json",
  "title": "Axeyum Rules-as-Code Pack Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "domain",
    "jurisdiction",
    "source_citations",
    "effective_interval",
    "actors",
    "inputs",
    "outputs",
    "checks",
    "axeyum_fragments",
    "proof_expectation"
  ],
  "properties": {
    "schema_version": {"type": "integer", "minimum": 1},
    "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
    "title": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "minLength": 1},
    "jurisdiction": {"type": "string", "minLength": 1},
    "source_citations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "uri"],
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "uri": {"type": "string", "minLength": 1}
        }
      }
    },
    "effective_interval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to"],
      "properties": {
        "from": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
        "to": {
          "anyOf": [
            {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
            {"type": "null"}
          ]
        }
      }
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/field"}
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/field"}
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "axeyum_fragments": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "proof_expectation": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "sort"],
      "properties": {
        "name": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "sort": {"type": "string", "minLength": 1}
      }
    }
  }
}
