  "checks": [
    {
      "id": "simplicial-complex-closure",
      "claim": "The filled triangle data is closed under non-empty faces.",
      "expected_result": "sat",
      "validation": "finite_simplicial_complex_replay",
      "proof_status": "replay-only",
      "witnesses": ["filled-triangle-complex"],
      "notes": "The validator checks that every non-empty face of every listed simplex is also listed and verifies the dimension counts."
    },
    {
      "id": "oriented-boundary-replay",
      "claim": "The oriented boundary of [a,b,c] is [b,c] - [a,c] + [a,b].",
      "expected_result": "sat",
      "validation": "finite_oriented_boundary_replay",
      "proof_status": "replay-only",
      "witnesses": ["triangle-boundary"],
      "notes": "The validator recomputes the alternating face sum with exact integer coefficients."
    },
    {
      "id": "boundary-squared-zero",
      "claim": "Applying the simplicial boundary twice to [a,b,c] gives the zero chain.",
      "expected_result": "sat",
      "validation": "finite_chain_complex_replay",
      "proof_status": "replay-only",
      "witnesses": ["triangle-boundary-square"],
      "notes": "The validator expands the first boundary, applies the edge boundary again, and checks that all vertex coefficients cancel."
    },
    {
      "id": "betti-rank-replay",
      "claim": "The three-edge circle has Betti numbers b0 = 1 and b1 = 1 over Q.",
      "expected_result": "sat",
      "validation": "finite_homology_rank_replay",
      "proof_status": "replay-only",
      "witnesses": ["circle-one-cycle"],
      "notes": "The validator builds boundary matrices over exact rationals, computes ranks by Gaussian elimination, and checks the listed cycle generator."
    },
    {
      "id": "bad-boundary-rejected",
      "claim": "The boundary of [a,b,c] is [b,c] + [a,c] + [a,b].",
      "expected_result": "unsat",
      "validation": "finite_bad_boundary_refutation",
      "proof_status": "checked",
      "data": {
        "vertices": ["a", "b", "c"],
        "simplex": ["a", "b", "c"],
        "claimed_boundary": [
          {"coefficient": "1", "simplex": ["b", "c"]},
          {"coefficient": "1", "simplex": ["a", "c"]},
          {"coefficient": "1", "simplex": ["a", "b"]}
        ],
        "actual_boundary": [
          {"coefficient": "1", "simplex": ["b", "c"]},
          {"coefficient": "-1", "simplex": ["a", "c"]},
          {"coefficient": "1", "simplex": ["a", "b"]}
        ],
        "first_mismatch_simplex": ["a", "c"],
        "claimed_coefficient": "1",
        "actual_coefficient": "-1"
      },
      "notes": "The validator recomputes the alternating boundary and checks that the listed sign error is a real mismatch."
    },
    {
      "id": "qf-lia-bad-boundary-coefficient",
      "claim": "The coefficient of [a,c] in the boundary of [a,b,c] can be +1.",
