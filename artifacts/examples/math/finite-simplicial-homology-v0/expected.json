      "validation": "qf_lia_diophantine_evidence",
      "proof_status": "checked",
      "data": {
        "vertices": ["a", "b", "c"],
        "simplex": ["a", "b", "c"],
        "mismatch_simplex": ["a", "c"],
        "actual_coefficient": "-1",
        "claimed_coefficient": "1",
        "smt2_artifact": "artifacts/examples/math/finite-simplicial-homology-v0/smt2/bad-boundary-coefficient-diophantine-conflict.smt2",
        "proof_regression": "cargo test -p axeyum-solver --test math_resource_lia_routes finite_simplicial_bad_boundary_coefficient_emits_checked_diophantine_evidence",
        "certificate": "produce_diophantine_evidence emits Evidence::UnsatDiophantine checked by Evidence::check for the integer coefficient contradiction coeff_ac = -1 and coeff_ac = 1"
      },
      "notes": "The SMT-LIB artifact isolates the bad boundary sign as an integer coefficient contradiction. Axeyum emits a Diophantine certificate for the inconsistent equalities."
    },
    {
