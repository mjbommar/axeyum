(set-logic QF_LRA)
(declare-const delta_a Real)
(declare-const delta_b Real)
(declare-const delta_c Real)
(declare-const twice_total_variation Real)
(declare-const total_variation Real)
(assert (= delta_a (/ 1 6)))
(assert (= delta_b 0))
(assert (= delta_c (/ 1 6)))
(assert (= twice_total_variation (+ delta_a delta_b delta_c)))
(assert (= twice_total_variation (* 2 total_variation)))
(assert (= total_variation (/ 1 4)))
(check-sat)
