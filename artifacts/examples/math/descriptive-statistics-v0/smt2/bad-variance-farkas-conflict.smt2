(set-logic QF_LRA)
(declare-const population_variance Real)
(declare-const second_moment Real)
(declare-const mean_square Real)
(assert (= second_moment (/ 15 2)))
(assert (= mean_square (/ 25 4)))
(assert (= (+ population_variance mean_square) second_moment))
(assert (= population_variance (/ 3 2)))
(check-sat)
