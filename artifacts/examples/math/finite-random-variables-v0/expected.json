          "clear": "short",
          "rain": "medium",
          "storm": "long"
        },
        "pushforward_distribution": {
          "short": "1/2",
          "medium": "1/4",
          "long": "1/4"
        },
        "outcome_values": {
          "short": "10",
          "medium": "20",
          "long": "40"
        },
        "source_expectation": "20",
        "pushforward_expectation": "20"
      }
    },
    {
      "id": "coin-signal-independent-random-variables",
