(set-logic QF_LRA)
(declare-const claimed_union_measure Real)
(declare-const left_measure Real)
(declare-const right_measure Real)
(assert (= claimed_union_measure (/ 3 2)))
(assert (= left_measure (/ 1 2)))
(assert (= right_measure (/ 5 6)))
(assert (<= claimed_union_measure (+ left_measure right_measure)))
(check-sat)
