{
  "schema_version": 1,
  "pack_id": "finite-measure-v0",
  "witnesses": [
    {
      "id": "partition-sigma-algebra",
      "description": "A four-set sigma-algebra generated by a two-block partition.",
      "values": {
        "universe": ["a", "b", "c", "d"],
        "measurable_sets": [
          [],
          ["a", "b"],
          ["c", "d"],
          ["a", "b", "c", "d"]
        ]
      }
    },
    {
      "id": "partition-probability-measure",
      "description": "An exact finite probability measure over the partition sigma-algebra.",
      "values": {
        "universe": ["a", "b", "c", "d"],
        "measurable_sets": [
          [],
          ["a", "b"],
          ["c", "d"],
          ["a", "b", "c", "d"]
        ],
        "measures": [
          {"set": [], "measure": "0"},
          {"set": ["a", "b"], "measure": "1/3"},
          {"set": ["c", "d"], "measure": "2/3"},
          {"set": ["a", "b", "c", "d"], "measure": "1"}
        ]
      }
    },
    {
      "id": "event-complement",
      "description": "The event {a,b} has complement {c,d}; their measures sum to one.",
      "values": {
        "universe": ["a", "b", "c", "d"],
        "measurable_sets": [
          [],
          ["a", "b"],
          ["c", "d"],
          ["a", "b", "c", "d"]
        ],
        "measures": [
          {"set": [], "measure": "0"},
          {"set": ["a", "b"], "measure": "1/3"},
          {"set": ["c", "d"], "measure": "2/3"},
          {"set": ["a", "b", "c", "d"], "measure": "1"}
        ],
        "event": ["a", "b"],
        "event_measure": "1/3",
        "complement": ["c", "d"],
        "complement_measure": "2/3",
        "total_measure": "1"
      }
    }
  ],
  "checks": [
    {
      "id": "finite-sigma-algebra-axioms",
      "claim": "The listed finite family is a sigma-algebra.",
      "expected_result": "sat",
      "validation": "finite_sigma_algebra_replay",
      "proof_status": "replay-only",
      "witnesses": ["partition-sigma-algebra"],
      "notes": "The validator checks empty/universe membership, complements, and pairwise unions."
    },
    {
      "id": "finite-measure-additivity",
      "claim": "The listed table is a normalized finite measure over the sigma-algebra.",
      "expected_result": "sat",
      "validation": "exact_rational_finite_measure_replay",
      "proof_status": "replay-only",
      "witnesses": ["partition-probability-measure"],
      "notes": "The validator checks nonnegativity, mu(empty)=0, mu(universe)=1, and finite additivity on disjoint measurable sets."
    },
    {
      "id": "event-complement-measure",
      "claim": "The listed event and complement have measures that sum to the total measure.",
      "expected_result": "sat",
      "validation": "exact_rational_finite_measure_replay",
      "proof_status": "replay-only",
      "witnesses": ["event-complement"],
      "notes": "The validator recomputes the complement and checks event/complement/total measure identities."
    },
    {
      "id": "bad-complement-measure-rejected",
      "claim": "The event {a,b} has complement measure 1/2 while event and complement measures still sum to the total measure.",
      "expected_result": "unsat",
      "validation": "finite_measure_bad_complement_refutation",
      "proof_status": "checked",
      "data": {
        "source_witness": "event-complement",
        "claimed_complement_measure": "1/2",
        "smt2_artifact": "artifacts/examples/math/finite-measure-v0/smt2/bad-complement-measure-farkas-conflict.smt2",
        "farkas_regression": "cargo test -p axeyum-solver --test math_resource_lra_routes finite_measure_bad_complement_artifact_emits_checked_farkas"
      },
      "notes": "The validator replays the finite measure table to compute mu({a,b}) = 1/3 and total measure 1; the source artifact checks the final contradiction mu(A) + 1/2 = 1 through QF_LRA/Farkas evidence."
    }
  ]
}
