      "values": {
        "universe": ["a", "b", "c", "d"],
        "measurable_sets": [
          [],
          ["a", "b"],
          ["c", "d"],
          ["a", "b", "c", "d"]
        ]
      }
    },
    {
      "id": "partition-probability-measure",
      "description": "An exact finite probability measure over the partition sigma-algebra.",
      "values": {
        "universe": ["a", "b", "c", "d"],
        "measurable_sets": [
          [],
          ["a", "b"],
          ["c", "d"],
          ["a", "b", "c", "d"]
        ],
        "measures": [
          {"set": [], "measure": "0"},
          {"set": ["a", "b"], "measure": "1/3"},
          {"set": ["c", "d"], "measure": "2/3"},
          {"set": ["a", "b", "c", "d"], "measure": "1"}
        ]
      }
    },
    {
      "id": "event-complement",
      "description": "The event {a,b} has complement {c,d}; their measures sum to one.",
      "values": {
        "universe": ["a", "b", "c", "d"],
        "measurable_sets": [
          [],
          ["a", "b"],
          ["c", "d"],
          ["a", "b", "c", "d"]
        ],
        "measures": [
          {"set": [], "measure": "0"},
          {"set": ["a", "b"], "measure": "1/3"},
          {"set": ["c", "d"], "measure": "2/3"},
          {"set": ["a", "b", "c", "d"], "measure": "1"}
        ],
        "event": ["a", "b"],
        "event_measure": "1/3",
        "complement": ["c", "d"],
        "complement_measure": "2/3",
        "total_measure": "1"
      }
    }
  ],
  "checks": [
    {
      "id": "finite-sigma-algebra-axioms",
      "claim": "The listed finite family is a sigma-algebra.",
      "expected_result": "sat",
      "validation": "finite_sigma_algebra_replay",
      "proof_status": "replay-only",
      "witnesses": ["partition-sigma-algebra"],
      "notes": "The validator checks empty/universe membership, complements, and pairwise unions."
    },
    {
      "id": "finite-measure-additivity",
      "claim": "The listed table is a normalized finite measure over the sigma-algebra.",
      "expected_result": "sat",
      "validation": "exact_rational_finite_measure_replay",
      "proof_status": "replay-only",
      "witnesses": ["partition-probability-measure"],
      "notes": "The validator checks nonnegativity, mu(empty)=0, mu(universe)=1, and finite additivity on disjoint measurable sets."
