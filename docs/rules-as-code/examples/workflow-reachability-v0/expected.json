{
  "schema_version": 1,
  "pack_id": "workflow_reachability_v0",
  "parameters": {
    "states": ["submitted", "under_review", "approved", "rejected"],
    "actions": ["request_review", "approve", "reject"],
    "terminal_states": ["approved", "rejected"],
    "initial_state": "submitted",
    "review_state": "under_review",
    "approved_state": "approved",
    "rejected_state": "rejected"
  },
  "sample_domain": {
    "states": ["submitted", "under_review", "approved", "rejected"],
    "actions": ["request_review", "approve", "reject"],
    "booleans": [false, true]
  },
  "witnesses": [
    {
      "id": "submitted_request_review",
      "facts": {
        "current_state": "submitted",
        "action": "request_review",
        "supervisor_review": false
      },
      "expected_allowed": true,
      "expected_next_state": "under_review",
      "source_citations": ["Example Rule 7(a)"],
      "explanation": "A submitted application can enter review."
    },
    {
      "id": "submitted_approve_denied",
      "facts": {
        "current_state": "submitted",
        "action": "approve",
        "supervisor_review": true
      },
      "expected_allowed": false,
      "expected_next_state": "submitted",
      "source_citations": ["Example Rule 7(a)", "Example Rule 7(b)"],
      "explanation": "Approval is not available before the application is under review."
    },
    {
      "id": "review_approve_with_supervisor",
      "facts": {
        "current_state": "under_review",
        "action": "approve",
        "supervisor_review": true
      },
      "expected_allowed": true,
      "expected_next_state": "approved",
      "source_citations": ["Example Rule 7(b)"],
      "explanation": "Supervisor review enables approval from the under-review state."
    },
    {
      "id": "approved_terminal_noop",
      "facts": {
        "current_state": "approved",
        "action": "request_review",
        "supervisor_review": true
      },
      "expected_allowed": false,
      "expected_next_state": "approved",
      "source_citations": ["Example Rule 7(d)"],
      "explanation": "Approved is terminal in this bounded workflow."
    }
  ],
  "checks": [
    {
      "id": "transition_witnesses",
      "expected_result": "sat",
      "validation": "witness_replay",
      "witnesses": ["submitted_request_review", "submitted_approve_denied", "review_approve_with_supervisor", "approved_terminal_noop"],
      "proof_status": "replayed",
      "source_citations": ["Example Rule 7(a)", "Example Rule 7(b)", "Example Rule 7(d)"]
    },
    {
      "id": "no_skip_to_approved",
      "expected_result": "unsat",
      "validation": "bool_qf_lia_solver_regression",
      "proof_status": "checked",
      "source_citations": ["Example Rule 7(a)", "Example Rule 7(b)"],
      "data": {
