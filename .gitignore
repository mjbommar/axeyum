# Rust build artifacts
/target

# Local reference clones (recreate with scripts/fetch-references.sh)
/references/*/

# Editor and OS noise
*.swp
.DS_Store
.idea/
.vscode/
__pycache__/
*.py[cod]

# Benchmark scratch output
/bench-results/local/

# cargo-mutants working/output directory
/mutants.out/

# Public corpus tier (fetched, not committed)
/corpus/public/

# mdBook generated site + mermaid runtime assets
# (regenerate: `cargo install mdbook mdbook-mermaid && mdbook-mermaid install . && mdbook build`)
/book/
/mermaid.min.js
/mermaid-init.js

# WASM playground bundle (regenerate: `wasm-pack build crates/axeyum-wasm --target web --out-dir docs/playground/pkg`)
/docs/playground/pkg/
